# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Supabase transaction connection string (Port 6543)
DATABASE_URL=""

# DIRECT_URL: Supabase session connection string (Port 5432)
DIRECT_URL=""

# Supabase Keys
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
SUPABASE_SECRET_KEY=""

# GOOGLE_SERVICE_ACCOUNT_CREDENTIALS: JSON string of your Google Cloud Service Account credentials
# Used for automatically generating Google Meet links via Calendar API
GOOGLE_SERVICE_ACCOUNT_CREDENTIALS=

# GOOGLE_CALENDAR_ID: The email address or ID of the calendar to create events on (default is 'primary')
GOOGLE_CALENDAR_ID=