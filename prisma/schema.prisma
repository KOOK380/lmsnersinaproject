generator client {
  provider = "prisma-client-js"
}

model Review {
  id           String      @id @default(uuid())
  courseId     String?
  membershipId String?
  userId       String
  rating       Int
  comment      String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  course       Course?     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  membership   Membership? @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  name           String
  phone          String?
  passwordHash   String
  role           String           @default("USER") // USER, ADMIN
  resetToken     String?
  resetTokenExpiry DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  memberships    MembershipOrder[]
  bookings       Booking[]
  cart           Cart?
  orders         Order[]
  courses        UserCourse[]
  emailLogs      EmailLog[]
  favorites      Favorite[]
  reviews        Review[]
  pushTokens     PushToken[]
}

model PushToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Float
  realPrice   Float?
  imageUrl    String?
  bannerVideoUrl String?
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  labels      String[]  @default([])
  
  duration    String?  @default("21 Days")
  language    String?  @default("Arabic")
  level       String?  @default("Beginner Level")
  isFeatured  Boolean  @default(false)
  isUpcoming  Boolean  @default(false)
  isActive    Boolean  @default(true)
  expiryDate  DateTime?
  meetingLink  String?
  meetingDate  DateTime?
  meetingNotes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  instructorId String?
  instructor   Instructor? @relation(fields: [instructorId], references: [id])

  lessons      Lesson[]
  users        UserCourse[]
  editions     CourseEdition[]
  translations CourseTranslation[]
  reviews      Review[]
  bundledIn    CourseBundleItem[]
  
  memberships  Membership[] @relation("CourseMemberships")
}

model CourseEdition {
  id              String   @id @default(uuid())
  courseId        String
  title           String
  content         String?
  mode            String?
  date            DateTime?
  totalSeats      Int?
  availableSeats  Int?
  
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userCourses     UserCourse[]
  translations    CourseEditionTranslation[]
}

model CourseEditionTranslation {
  id           String @id @default(uuid())
  editionId    String
  languageCode String
  title        String
  
  edition      CourseEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@unique([editionId, languageCode])
}

model Instructor {
  id        String   @id @default(uuid())
  name      String
  imageUrl  String?
  bio       String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courses   Course[]
}

model Lesson {
  id          String   @id @default(uuid())
  title       String
  videoUrl    String?
  content     String?
  duration    String?
  description String?
  showAboutCourse Boolean @default(true)
  order       Int      @default(0)
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  translations LessonTranslation[]
}

model LessonTranslation {
  id           String @id @default(uuid())
  lessonId     String
  languageCode String
  title        String
  description  String?
  
  lesson       Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, languageCode])
}

model UserCourse {
  id          String   @id @default(uuid())
  userId      String
  courseId    String
  progress    Int      @default(0) // percentage
  expiresAt   DateTime?
  editionId   String?
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  edition     CourseEdition? @relation(fields: [editionId], references: [id])

  @@unique([userId, courseId])
}

model Membership {
  id          String   @id @default(uuid())
  type        String   // STANDARD, PROGRAM
  imageUrl    String?
  label       String?
  realPrice   Float?
  offerPrice  Float
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  expiryDate  DateTime?
  meetingLink  String?
  meetingDate  DateTime?
  meetingNotes String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contents    MembershipContent[]
  editions    MembershipEdition[]
  orders      MembershipOrder[]
  reviews     Review[]
  courses     Course[] @relation("CourseMemberships")
}

model MembershipContent {
  id              String   @id @default(uuid())
  membershipId    String
  language        String   // en, ar, fr
  title           String
  description     String
  whoIsFor        String?
  benefits        String?  // JSON string or newlines
  entryCondition  String?
  keyDetails      String?
  
  membership      Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, language])
}

model MembershipEdition {
  id              String   @id @default(uuid())
  membershipId    String
  title           String
  date            DateTime
  mode            String   // online, offline
  totalSeats      Int
  availableSeats  Int
  
  membership      Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  orders          MembershipOrder[]
}

model MembershipOrder {
  id              String   @id @default(uuid())
  userId          String
  membershipId    String
  editionId       String?
  status          String   @default("ACTIVE")
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  
  user            User               @relation(fields: [userId], references: [id])
  membership      Membership         @relation(fields: [membershipId], references: [id])
  edition         MembershipEdition? @relation(fields: [editionId], references: [id])
}

model Testimonial {
  id        String   @id @default(uuid())
  name      String
  role      String?
  text      String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id             String   @id @default(uuid())
  title          String
  description    String
  date           DateTime
  endDate        DateTime?
  expiryDate     DateTime?
  totalSeats     Int
  availableSeats Int
  price          Float
  realPrice      Float?
  location       String?
  imageUrl       String?
  meetingLink  String?
  meetingDate  DateTime?
  meetingNotes String?
  createdAt      DateTime @default(now())
  
  bookings       Booking[]
  translations   EventTranslation[]
}

model EventTranslation {
  id           String @id @default(uuid())
  eventId      String
  languageCode String // en, ar, fr
  title        String
  description  String
  
  event        Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, languageCode])
}

model Booking {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  status    String   @default("CONFIRMED")
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])
}

model Cart {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  
  items     CartItem[]
}

model CartItem {
  id               String   @id @default(uuid())
  cartId           String
  itemType         String   // COURSE, MEMBERSHIP, EVENT
  itemId           String
  editionId        String?
  cart             Cart     @relation(fields: [cartId], references: [id])
}

model Order {
  id              String      @id @default(uuid())
  userId          String
  total           Float
  status          String      @default("COMPLETED")
  paymentMethod   String      @default("STRIPE") // STRIPE, MANUAL
  billingDetails  String?     // Stored as JSON string
  paymentProofUrl String?     // e.g. receipt image for manual payment
  rejectReason    String?     // holds manual payment rejection explanation
  createdAt       DateTime    @default(now())
  
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]
}

model OrderItem {
  id           String    @id @default(uuid())
  orderId      String
  itemType     String    // COURSE, MEMBERSHIP, EVENT
  itemId       String
  editionId    String?
  price        Float
  order        Order     @relation(fields: [orderId], references: [id])
}

model Slider {
  id        String   @id @default(uuid())
  title     String
  imageUrl  String
  linkUrl   String?
  active    Boolean  @default(true)
}

model EmailCampaign {
  id          String   @id @default(uuid())
  subject     String
  message     String
  type        String   // UPDATE: SELECTED, COURSE, MEMBERSHIP, EVENT, ALL
  targetId    String?  // UPDATE: replaces courseId
  status      String   @default("PENDING") // ADDED: PENDING, SENT, CANCELLED
  scheduledAt DateTime? // ADDED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs      EmailLog[]
}

model EmailLog {
  id            String   @id @default(uuid())
  campaignId    String?
  userId        String
  status        String   @default("SENT")
  sentAt        DateTime @default(now())

  campaign      EmailCampaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailTemplate {
  id          String   @id @default(uuid())
  type        String   @unique // COURSE_PURCHASE, MEMBERSHIP_PURCHASE, EVENT_BOOKING
  subject     String
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SeoMeta {
  id          String   @id @default(uuid())
  entityType  String   // COURSE, MEMBERSHIP, EVENT, PAGE
  entityId    String   // courseId, membershipId, etc., or route path
  title       String?
  description String?
  keywords    String?
  updatedAt   DateTime @updatedAt
  
  @@unique([entityType, entityId])
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  source    String   @default("CONTACT_FORM") // CONTACT_FORM, NEWSLETTER
  createdAt DateTime @default(now())
}

model Setting {
  key         String   @id
  value       String   // JSON string
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Inquiry {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  status    String   @default("NEW")
  createdAt DateTime @default(now())
}

model Language {
  id           String   @id @default(uuid())
  code         String   @unique // en, ar, fr
  name         String   // English, Arabic, French
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  translations String   @default("{}") // JSON string of UI translations
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CourseTranslation {
  id           String @id @default(uuid())
  courseId     String
  languageCode String // en, ar, fr
  title        String
  description  String
  
  course       Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  @@unique([courseId, languageCode])
}

model Category {
  id          String   @id @default(uuid())
  type        String   @default("COURSE") // COURSE or MEMBERSHIP
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses     Course[]
  memberships Membership[]
  translations CategoryTranslation[]
}

model CategoryTranslation {
  id           String @id @default(uuid())
  categoryId   String
  languageCode String
  name         String
  description  String?
  
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, languageCode])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  itemType  String   // COURSE, MEMBERSHIP
  itemId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType, itemId])
}

model Blog {
  id          String   @id @default(uuid())
  title       String
  category    String?
  imageUrl    String?
  content     String   @default("")
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  translations BlogTranslation[]
}

model BlogTranslation {
  id           String @id @default(uuid())
  blogId       String
  languageCode String
  title        String
  content      String?
  
  blog         Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@unique([blogId, languageCode])
}

model CourseBundle {
  id              String   @id @default(uuid())
  title           String
  description     String
  price           Float
  realPrice       Float?
  imageUrl        String?
  bannerVideoUrl  String?
  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  courses         CourseBundleItem[]
  translations    CourseBundleTranslation[]
}

model CourseBundleItem {
  id              String   @id @default(uuid())
  bundleId        String
  courseId        String

  bundle          CourseBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  course          Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([bundleId, courseId])
}

model CourseBundleTranslation {
  id              String @id @default(uuid())
  bundleId        String
  languageCode    String
  title           String
  description     String

  bundle          CourseBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  @@unique([bundleId, languageCode])
}

